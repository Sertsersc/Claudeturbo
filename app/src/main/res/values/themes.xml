<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TurboAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_glow</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColor">@color/text_white</item>
    </style>

    <style name="PurpleButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_purple</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">30dp</item>
        <item name="rippleColor">@color/purple_light</item>
    </style>
</resources>
