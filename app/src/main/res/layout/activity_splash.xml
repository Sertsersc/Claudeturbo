<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <!-- Arka glow efekti -->
    <View
        android:id="@+id/glowCircle"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVerticalBias="0.35"/>

    <!-- Başlık -->
    <TextView
        android:id="@+id/meetText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meet the"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/turboText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Turbo AI!"
        android:textColor="#A855F7"
        android:textSize="42sp"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/meetText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Robot ikonu -->
    <ImageView
        android:id="@+id/robotIcon"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_launcher"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/turboText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Balon -->
    <TextView
        android:id="@+id/bubbleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sana nasıl yardımcı olabilirim?"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/bg_bubble"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/robotIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Başla butonu -->
    <Button
        android:id="@+id/startBtn"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="Başla  ›››"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="@drawable/bg_button_purple"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
